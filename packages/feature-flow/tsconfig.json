{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["extension-src/feature-flow/*"],
      "@app/*": ["extension-src/feature-flow/app/*"],
      "@domain/*": ["extension-src/feature-flow/domain/*"],
      "@pi/*": ["extension-src/feature-flow/pi/*"],
      "@templates/*": ["extension-src/feature-flow/templates/*"]
    },
    "types": ["node", "vitest/globals"]
  },
  "include": ["extension-src/**/*.ts", "tests/**/*.ts"]
}
