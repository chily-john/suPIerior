{
  "name": "@supierior/kanban-converters",
  "version": "0.1.0-beta.1",
  "description": "Kanban converter contracts and built-in GitHub issue publishing for Pi feature workflows.",
  "keywords": [
    "pi",
    "kanban",
    "github",
    "issues"
  ],
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm run lint:deps",
    "lint:deps": "depcruise extension-src --config scripts/.dependency-cruiser.cjs",
    "clean": "rimraf dist coverage .turbo",
    "prepack": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "dependency-cruiser": "^16.10.4",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
